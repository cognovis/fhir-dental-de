### ValueSet: GozCodesVS - Expand
# VS URL: https://fhir.cognovis.de/dental/ValueSet/goz-codes
# Expected: expansion.contains has 300 entries
GET http://localhost:8080/ValueSet/goz-codes/$expand
Authorization: Basic basic:secret

### ValueSet: GozCodesVS - Validate Valid Code (0010)
# System: http://fhir.de/CodeSystem/bzaek/goz
# Expected: result=true
# Actual: result=True
GET http://localhost:8080/ValueSet/$validate-code?url=https://fhir.cognovis.de/dental/ValueSet/goz-codes&system=http://fhir.de/CodeSystem/bzaek/goz&code=0010
Authorization: Basic basic:secret

### ValueSet: GozCodesVS - Validate Valid Code (0020)
# System: http://fhir.de/CodeSystem/bzaek/goz
# Expected: result=true
# Actual: result=True
GET http://localhost:8080/ValueSet/$validate-code?url=https://fhir.cognovis.de/dental/ValueSet/goz-codes&system=http://fhir.de/CodeSystem/bzaek/goz&code=0020
Authorization: Basic basic:secret

### ValueSet: GozCodesVS - Validate Invalid Code
# System: http://fhir.de/CodeSystem/bzaek/goz
# Expected: result=false
# Actual: result=False
GET http://localhost:8080/ValueSet/$validate-code?url=https://fhir.cognovis.de/dental/ValueSet/goz-codes&system=http://fhir.de/CodeSystem/bzaek/goz&code=INVALID_XYZ
Authorization: Basic basic:secret
