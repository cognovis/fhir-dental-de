### ValueSet: ScheintypVS - Expand
# VS URL: https://fhir.cognovis.de/dental/ValueSet/scheintyp
# Expected: expansion.contains has 6 entries
GET http://localhost:8080/ValueSet/scheintyp/$expand
Authorization: Basic basic:secret

### ValueSet: ScheintypVS - Validate Valid Code (kassenschein)
# System: https://fhir.cognovis.de/dental/CodeSystem/scheintyp
# Expected: result=true
# Actual: result=True
GET http://localhost:8080/ValueSet/$validate-code?url=https://fhir.cognovis.de/dental/ValueSet/scheintyp&system=https://fhir.cognovis.de/dental/CodeSystem/scheintyp&code=kassenschein
Authorization: Basic basic:secret

